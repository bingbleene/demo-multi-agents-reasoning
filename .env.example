# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Maximum tokens allowed in agent message history
MAX_TOTAL_TOKENS=4096

# Maximum tokens for chat history
MAX_CHAT_HISTORY_TOKENS=4096

# Maximum number of refinement attempts allowed
MAX_REFINEMENT_ATTEMPTS=3

# Maximum number of retry attempts for API calls
RETRY_LIMIT=3

# Backoff multiplier for exponential retry delays (base * factor ^ attempt)
RETRY_BACKOFF_FACTOR=2

# Path to agents configuration file
AGENTS_CONFIG_FILE=agents.json

# Path to reasoning history file
REASONING_HISTORY_FILE=reasoning_history.json